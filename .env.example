# ============================================================
#  WMS Pro — Environment Configuration
#  Đổi tên file này từ .env.example → .env
#  KHÔNG commit file .env lên Git
# ============================================================

# ── Server ──────────────────────────────────────
PORT=3001
NODE_ENV=production          # production | development

# ── MySQL ───────────────────────────────────────
DB_HOST=localhost            # hoặc IP của MySQL server
DB_PORT=3306
DB_NAME=wms_pro
DB_USER=wms_user             # KHÔNG dùng root cho production
DB_PASSWORD=YourStrongPass!  # Đổi mật khẩu mạnh
DB_POOL_MIN=2                # Connection pool tối thiểu
DB_POOL_MAX=20               # Connection pool tối đa

# ── JWT Auth ─────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=8h            # Token hết hạn sau 8 giờ
JWT_REFRESH_EXPIRES_IN=7d    # Refresh token 7 ngày

# ── CORS ─────────────────────────────────────────
# Danh sách origin được phép (cách nhau bằng dấu phẩy)
ALLOWED_ORIGINS=http://localhost:5173,http://YOUR_VPS_IP,https://your-domain.com

# ── File upload ───────────────────────────────────
UPLOAD_MAX_SIZE_MB=10        # Giới hạn file upload (MB)
UPLOAD_DIR=./uploads         # Thư mục lưu file tạm

# ── Rate limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000  # 15 phút
RATE_LIMIT_MAX=500           # Tối đa 500 request / 15 phút / IP
